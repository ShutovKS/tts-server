# qwen3-tts runtime paths
QWEN_TTS_MODELS_DIR=.models
QWEN_TTS_OUTPUTS_DIR=.outputs
QWEN_TTS_VOICES_DIR=.voices

# backend/runtime
# Leave empty to use automatic backend selection.
# Supported values depend on available runtime backends, for example: torch, mlx.
QWEN_TTS_BACKEND=
QWEN_TTS_BACKEND_AUTOSELECT=true
QWEN_TTS_ENABLE_STREAMING=true
QWEN_TTS_REQUEST_TIMEOUT_SECONDS=300
QWEN_TTS_INFERENCE_BUSY_STATUS_CODE=503

# audio/output
QWEN_TTS_DEFAULT_SAVE_OUTPUT=false
QWEN_TTS_SAMPLE_RATE=24000
QWEN_TTS_FILENAME_MAX_LEN=20
QWEN_TTS_MAX_UPLOAD_SIZE_BYTES=26214400
QWEN_TTS_AUTO_PLAY_CLI=true

# server
QWEN_TTS_HOST=0.0.0.0
QWEN_TTS_PORT=8000
QWEN_TTS_LOG_LEVEL=info
