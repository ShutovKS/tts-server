# qwen3-tts runtime paths
QWEN_TTS_MODELS_DIR=.models
QWEN_TTS_OUTPUTS_DIR=.outputs
QWEN_TTS_VOICES_DIR=.voices

# backend/runtime
# Leave empty to use automatic backend selection.
# Supported values depend on available runtime backends, for example: torch, mlx.
QWEN_TTS_BACKEND=
QWEN_TTS_BACKEND_AUTOSELECT=true
QWEN_TTS_ENABLE_STREAMING=true
QWEN_TTS_REQUEST_TIMEOUT_SECONDS=300
QWEN_TTS_INFERENCE_BUSY_STATUS_CODE=503

# audio/output
QWEN_TTS_DEFAULT_SAVE_OUTPUT=false
QWEN_TTS_SAMPLE_RATE=24000
QWEN_TTS_FILENAME_MAX_LEN=20
QWEN_TTS_MAX_UPLOAD_SIZE_BYTES=26214400
QWEN_TTS_AUTO_PLAY_CLI=true

# server
QWEN_TTS_HOST=0.0.0.0
QWEN_TTS_PORT=8000
QWEN_TTS_LOG_LEVEL=info

# telegram bot (separate process)
#
# REQUIREMENTS:
# - ffmpeg must be available in PATH (required for audio conversion)
# - Get bot token from @BotFather
#
QWEN_TTS_TELEGRAM_BOT_TOKEN=
# Security: Comma-separated user IDs for allowlist (empty = all users allowed, NOT recommended for production)
QWEN_TTS_TELEGRAM_ALLOWED_USER_IDS=
# Security: Admin user IDs with elevated access (bypass rate limiting)
QWEN_TTS_TELEGRAM_ADMIN_USER_IDS=
# Security: Enable dev mode with relaxed security checks (default: false - set to true only for development)
QWEN_TTS_TELEGRAM_DEV_MODE=false
# Security: Enable per-user rate limiting (default: true)
QWEN_TTS_TELEGRAM_RATE_LIMIT_ENABLED=true
# Security: Max requests per user per minute (default: 20)
QWEN_TTS_TELEGRAM_RATE_LIMIT_PER_USER_PER_MINUTE=20
# Operational: Log level for Telegram bot (default: info)
QWEN_TTS_TELEGRAM_LOG_LEVEL=info
# Operational: Default speaker name (default: Vivian)
QWEN_TTS_TELEGRAM_DEFAULT_SPEAKER=Vivian
# Operational: Maximum text length for /tts command (default: 1000, max: 5000)
QWEN_TTS_TELEGRAM_MAX_TEXT_LENGTH=1000
# Operational: Persistent path for Telegram delivery-state metadata (recommended for bot restarts)
QWEN_TTS_TELEGRAM_DELIVERY_STORE_PATH=.state/telegram_delivery_store.json
# Operational: Job poller interval in seconds (default: 1.0)
QWEN_TTS_TELEGRAM_POLL_INTERVAL_SECONDS=1.0
# Operational: Max retry attempts for API calls (default: 3)
QWEN_TTS_TELEGRAM_MAX_RETRIES=3
